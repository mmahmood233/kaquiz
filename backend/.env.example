# Port used by the backend server.
PORT=3000

# Old MongoDB setting kept for compatibility; this project currently uses SQLite.
MONGODB_URI=mongodb://localhost:27017/friend-finder

# Secret key used to sign login tokens. Change this in real production apps.
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# How long login tokens stay valid.
JWT_EXPIRE=7d

# App environment. Use development locally.
NODE_ENV=development

# Google Maps API key used by the mobile map.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
